{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Everlast AI Recorder",
  "version": "0.1.0",
  "identifier": "ai.everlast.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Everlast AI Recorder",
        "width": 440,
        "height": 600,
        "minWidth": 380,
        "minHeight": 500,
        "maxWidth": 520,
        "maxHeight": 750,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.auth0.com https://api.deepgram.com https://api.elevenlabs.io https://api.openai.com https://api.anthropic.com wss://api.deepgram.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.auth0.com https://*.gravatar.com; media-src 'self' blob:; font-src 'self' data:; frame-src 'self' https://*.auth0.com"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["everlastai"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "createUpdaterArtifacts": false,
    "category": "Productivity",
    "shortDescription": "Voice to Enriched Text",
    "longDescription": "Transform your voice into structured, AI-enriched content with Everlast AI Recorder",
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
